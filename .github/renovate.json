{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "default:automergeDigest",
    "docker:pinDigests"
  ],
  "dependencyDashboard": false,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "PostgreSQL major upgrades need a manual data migration (pg_upgrade/dump-restore) - never propose them automatically",
      "matchPackageNames": [
        "registry-1.docker.io/bitnamicharts/postgresql",
        "postgres",
        "pgvector/pgvector"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ],
  "argocd": {
    "managerFilePatterns": [
      "/apps/templates/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/apps/templates/.+\\.yaml$/"
    ]
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "nix": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/apps/templates/helm-factorio.yaml$/"
      ],
      "matchStrings": [
        "#\\s?renovate: image=(?<depName>.*?)\\s+?tag:\\s?\\\"?(?<currentValue>[\\w+\\.\\-]*)(@(?<currentDigest>sha256:[0-9a-f]*))?\\\"?"
      ],
      "versioningTemplate": "loose"
    }
  ]
}
